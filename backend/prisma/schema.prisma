generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  categories   Category[]
  products     Product[]
  sales        Sale[]
  activityLogs ActivityLog[]
  settings     AppSetting[]
  parkedBills  ParkedBill[]
  backups      BackupSnapshot[]
  syncLogs     SyncLog[]
}

model User {
  id           String   @id
  shopId       String
  username     String
  displayName  String
  pin          String
  passwordHash String
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, username])
  @@index([shopId, pin])
}

model Category {
  id        String   @id
  shopId    String
  name      String
  color     String
  icon      String?
  sortOrder Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([shopId, sortOrder])
}

model Product {
  id          String   @id
  shopId      String
  categoryId  String
  name        String
  displayName String
  price       Decimal  @db.Decimal(12, 2)
  color       String
  sortOrder   Int
  isActive    Boolean  @default(true)
  isOpenPrice Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([shopId, categoryId, sortOrder])
}

model Sale {
  id              String   @id
  shopId          String
  billNo          String
  cashierId       String
  cashierName     String
  subtotal        Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @db.Decimal(12, 2)
  discountPercent Decimal  @db.Decimal(6, 2)
  total           Decimal  @db.Decimal(12, 2)
  status          String
  voidReason      String?
  voidedByUserId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items     SaleItem[]
  payments  Payment[]
  discounts DiscountLog[]

  @@unique([shopId, billNo])
  @@index([shopId, createdAt])
  @@index([shopId, status])
}

model SaleItem {
  id              String   @id
  saleId          String
  productId       String
  productName     String
  price           Decimal  @db.Decimal(12, 2)
  quantity        Int
  subtotal        Decimal  @db.Decimal(12, 2)
  discountAmount  Decimal  @db.Decimal(12, 2)
  discountPercent Decimal  @db.Decimal(6, 2)
  total           Decimal  @db.Decimal(12, 2)
  note            String?
  isOpenPrice     Boolean  @default(false)
  createdAt       DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id             String   @id
  saleId         String
  method         String
  amount         Decimal  @db.Decimal(12, 2)
  receivedAmount Decimal  @db.Decimal(12, 2)
  changeAmount   Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
}

model DiscountLog {
  id               String   @id
  saleId           String
  saleItemId       String?
  discountType     String
  value            Decimal  @db.Decimal(12, 2)
  approvedByUserId String?
  createdAt        DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model ActivityLog {
  id         String   @id
  shopId     String
  userId     String
  action     String
  entityType String
  entityId   String
  detail     String
  createdAt  DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  // Supports the daily TTL prune (createdAt < cutoff, no shopId predicate)
  @@index([createdAt])
}

model AppSetting {
  key       String
  shopId    String
  value     String
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@id([shopId, key])
}

model ParkedBill {
  id        String   @id
  shopId    String
  name      String
  cartJson  String
  cashierId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, cashierId])
}

model SyncLog {
  id       String   @id @default(cuid())
  shopId   String
  deviceId String
  table    String
  recordId String
  action   String
  syncedAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, syncedAt])
  @@index([shopId, table, recordId])
  // Pull delete-feed: where shopId + action='delete' + syncedAt > cursor
  @@index([shopId, action, syncedAt])
  // Daily TTL prune (syncedAt < cutoff, no shopId predicate)
  @@index([syncedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  shopId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model BackupSnapshot {
  id         String   @id @default(cuid())
  shopId     String
  fileName   String
  storageUrl String
  sizeBytes  Int
  createdBy  String
  createdAt  DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
}
